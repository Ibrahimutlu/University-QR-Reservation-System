# ============================================================================
# Frontend — example environment variables
#
# The frontend is plain static HTML and reads its API URL at runtime from
# window.RRS_API_BASE (see frontend/js/config.js).
#
# To inject this on Vercel:
#   1. Go to Vercel project Settings -> Environment Variables.
#   2. Add VITE_API_BASE_URL or NEXT_PUBLIC_API_BASE_URL or our own
#      RRS_API_BASE.
#   3. Reference it in a small build step that emits a config.production.js
#      file with `window.RRS_API_BASE = "https://...railway.app";` BEFORE
#      js/config.js is loaded.
#
# For local development, just leave this file alone — config.js falls back to
# http://localhost:5000.
# ============================================================================

# Used by Vite-style frontends (if migrated later)
VITE_API_BASE_URL=http://localhost:5000

# Used by Next.js (if migrated later)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Custom name read by our static config.js when injected as a runtime global
RRS_API_BASE=http://localhost:5000
