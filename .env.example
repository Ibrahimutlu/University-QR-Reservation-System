# Copy to .env and fill real values. .env is gitignored.

# ── PostgreSQL ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=RoomReservationDB
DB_USER=postgres
DB_PASSWORD=change_me_locally

# ── ASP.NET Core ─────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001

# ── JWT (server-only secret) ─────────────────────
JWT_SECRET=replace_with_at_least_64_random_characters
JWT_EXPIRY_DAYS=7

# ── Frontend ─────────────────────────────────────
FRONTEND_API_BASE=http://localhost:5000
