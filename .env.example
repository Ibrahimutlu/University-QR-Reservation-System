# ============================================================================
# RoomLink — root example .env
# Copy to .env and fill real values. .env is gitignored.
# This file documents EVERY variable the project understands. Per-module
# .env.example files (backend/, frontend/) carry only the relevant subset.
# ============================================================================

# ── Local PostgreSQL (used by the dev fix-pg-bind.sh + manual psql) ─────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=RoomReservationDB
DB_USER=postgres
DB_PASSWORD=change_me_locally

# ── Backend (ASP.NET Core 5) ─────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# Local dev URLs.  In production (Railway), Railway sets PORT for you.
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001
# Used by Program.cs to bind 0.0.0.0:$PORT in containers.
PORT=5000

# Production-style DB connection (Railway / Neon / Supabase / Heroku).
# Standard URI form: postgres://user:password@host:port/dbname
DATABASE_URL=

# JWT signing secret. Must be at least 32 random chars in production.
JWT_SECRET=replace_with_at_least_64_random_characters
JWT_EXPIRY_DAYS=7

# Comma-separated list of frontend origins to allow via CORS in prod.
FRONTEND_URL=https://your-frontend.vercel.app

# QR rotation interval (minutes).  Read by QRService.GenerateDynamicQRValue.
QR_ROTATION_INTERVAL_MINUTES=2

# Grace period after a reservation start before it becomes Expired/NoShow.
CHECKIN_GRACE_PERIOD_MINUTES=15

# Force HTTPS redirect even outside Development.  Leave blank on Railway.
FORCE_HTTPS=

# ── Frontend (Vercel) ────────────────────────────────────────────────────────
# Used by frontend/js/config.js indirectly via window.RRS_API_BASE.
# Vercel can inject this at build time as an env var; see deployment guide.
FRONTEND_API_BASE=http://localhost:5000
