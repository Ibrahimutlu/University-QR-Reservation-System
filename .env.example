# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.
# ──────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=RoomReservationDB
DB_USER=postgres
DB_PASSWORD=change_me_locally

# ── ASP.NET Core ──────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# ── JWT (server-only secret — keep out of git) ────────────
JWT_SECRET=replace_with_at_least_64_random_characters
JWT_EXPIRY_DAYS=7

# ── Frontend (when added) ─────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000
