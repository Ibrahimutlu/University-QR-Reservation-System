# ============================================================================
# Backend (ASP.NET Core 5) — example .env
# Copy to .env and fill real values.  Variables read directly by the app:
#   * DATABASE_URL       — Postgres URI (Railway / Neon)
#   * JWT_SECRET         — token signing key
#   * FRONTEND_URL       — comma-separated CORS origins
#   * PORT               — bind port (Railway sets this for you)
#   * QR_ROTATION_INTERVAL_MINUTES  — default 2
#   * CHECKIN_GRACE_PERIOD_MINUTES  — default 15
#   * FORCE_HTTPS        — set to "true" to keep https redirection in prod
# ============================================================================

ASPNETCORE_ENVIRONMENT=Development
PORT=5000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/RoomReservationDB
JWT_SECRET=replace_with_at_least_64_random_characters
FRONTEND_URL=http://localhost:8000

QR_ROTATION_INTERVAL_MINUTES=2
CHECKIN_GRACE_PERIOD_MINUTES=15
